@@ -1,5 +1,6 @@
 #!/usr/bin/env python3
 
+import struct
 import unittest
 
 from framework import VppTestCase
@@ -10,6 +11,7 @@ from config import config
 from scapy.layers.inet import IP, UDP
 from scapy.layers.l2 import Ether
 from scapy.layers.dns import DNS, DNSQR
